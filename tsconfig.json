{
  "compilerOptions": {
    "target": "ES2022", "module": "ESNext", "moduleResolution": "bundler",
    "strict": true, "noUncheckedIndexedAccess": true, "skipLibCheck": true,
    "types": ["vite/client", "node"], "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "resolveJsonModule": true
  },
  "include": ["src", "tests"]
}
